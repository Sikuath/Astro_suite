requires 1.2

# ==================================================
# ASTRO STUDIO - STEP 03
# LINEAR MATCH
# Reference : HA
# ==================================================

cd process/linear

# --------------------------------------------------
# HA -> HA
# --------------------------------------------------

load HA.fit

save ../../HA_linear.fit

# --------------------------------------------------
# OIII -> HA
# --------------------------------------------------

load OIII.fit

linear_match HA.fit 0 1

save ../../OIII_linear.fit


# --------------------------------------------------
# SII -> HA
# --------------------------------------------------

load SII.fit

linear_match HA.fit 0 1

save ../../SII_linear.fit


# --------------------------------------------------
# END
# --------------------------------------------------

close